C {devices/code_shown.sym} -940 40 0 0 {name=MODEL only_toplevel=true
format="tcleval( @value )"
value="
.lib $::SG13G2_MODELS/cornerMOShv.lib mos_tt
.lib $::SG13G2_MODELS/cornerRES.lib res_typ
.lib $::SG13G2_MODELS/cornerCAP.lib cap_typ
.lib $::SG13G2_MODELS/cornerHBT.lib hbt_typ
"}
C {devices/code_shown.sym} -980 170 0 0 {name=NGSPICE only_toplevel=true
value="
.control
 save all

set temp=27
op
echo === OP node voltages ===
print net1 net2 net3 net4 inn eq
print n.xr1.nr1#i1 n.xr1.nr1#i2
print n.xm1.nsg13_hv_pmos#di
print n.xm3.nsg13_hv_pmos#di

dc temp -40 125 1

* Correct nodes after netlist analysis:
* Inn  = Q2 emitter = Vbe (CTAT reference)
* net2 = top of XR1 = OTA.Inp (tracks Inn when loop closed)
* net3 = bottom of XR1 = Q1 emitter
* ΔVbe = net2 - net3

let vbe   = dc1.inn
let vdvbe = dc1.net2 - dc1.net3
let veq   = dc1.eq
let vnet4 = dc1.net4

* Vbe CTAT stats
let vbe_max = vecmax(vbe)
let vbe_min = vecmin(vbe)
let vbe_nom = mean(vbe)
let tc_vbe  = ((vbe_max - vbe_min) / vbe_nom) * 1e6 / 165

* ΔVbe PTAT stats
let vr_max = vecmax(vdvbe)
let vr_min = vecmin(vdvbe)
let vr_nom = mean(vdvbe)
let tc_vr  = ((vr_max - vr_min) / vr_nom) * 1e6 / 165

* PTAT current
let i_ptat    = vdvbe / 13e3
let i_ptat_ua = i_ptat * 1e6

* CATA output
let veq_max = vecmax(veq)
let veq_min = vecmin(veq)
let veq_nom = mean(veq)
let tc_eq   = ((veq_max - veq_min) / veq_nom) * 1e6 / 165

echo === Vbe CTAT (Inn) ===
print vbe_max vbe_min vbe_nom tc_vbe

echo === Delta_Vbe PTAT (net2-net3) ===
print vr_max vr_min vr_nom tc_vr

echo === I_PTAT uA ===
print vecmax(i_ptat_ua) vecmin(i_ptat_ua) mean(i_ptat_ua)

echo === Eq bandgap output ===
print veq_max veq_min veq_nom tc_eq

echo === net4 Q3 emitter ===
print vecmax(vnet4) vecmin(vnet4) mean(vnet4)

plot dc1.inn title 'Vbe vs T (CTAT)'
plot dc1.net2 - dc1.net3 title 'Delta_Vbe vs T (PTAT)'
plot dc1.eq title 'Eq bandgap output vs T'
plot i_ptat_ua title 'I_PTAT uA vs T'

wrdata /tmp/bg_inn.txt dc1.inn
wrdata /tmp/bg_eq.txt dc1.eq

echo === Eq bandgap output ===
print veq_max veq_min veq_nom tc_eq

* Better TC calculation — use max deviation from nominal
let veq_center = (veq_max + veq_min) / 2
let tc_eq_pp = (veq_max - veq_min) / veq_center * 1e6 / 165
print tc_eq_pp


print v(Eq_buf)
print v(Out_0.48V)
print n.xr3.nr1#i1


.endc
"
}
